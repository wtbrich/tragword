OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MILVUS_DB_URI=./.milvus/milvus_local.db
MILVUS_COLLECTION_NAME=tragword
TOP_K=4
HYBRID_ENABLED=true
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATES=10
MULTIQUERY_ENABLED=false
SEARCH_ENABLED=true
MAX_REVISIONS=2
CHUNK_SIZE=800
CHUNK_OVERLAP=120

CHECKPOINT_DB=.langgraph/checkpoints.sqlite

# 首次运行会下载约 93M 的 bge-small-zh-v1.5 和约 1.1G 的 bge-reranker-base，默认缓存到 ~/.cache/huggingface
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_DOWNLOAD_TIMEOUT=60
# HF_HOME=/path/to/huggingface-cache
# EAGER_LOAD_MODELS=true
# RERANK_ENABLED=false  # 跳过 1.1G 重排模型
